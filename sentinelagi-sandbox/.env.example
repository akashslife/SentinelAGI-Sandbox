# ============================================
# SentinelAGI Sandbox - Environment Configuration
# ============================================
# Copy to .env and customize for your deployment

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# OpenAI (required for agent intelligence)
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Docker/gVisor Sandbox
SANDBOX_RUNTIME=runsc
SANDBOX_IMAGE=sentinelagi/agent-sandbox:latest
SANDBOX_NETWORK_MODE=none
SANDBOX_CPU_QUOTA=1.0
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_STORAGE_LIMIT=1g
SANDBOX_MAX_EXECUTION_TIME=300
SANDBOX_ENABLE_SECCOMP=true
SANDBOX_ENABLE_APPARMOR=true
SANDBOX_READ_ONLY_ROOTFS=true
SANDBOX_NO_NEW_PRIVILEGES=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_STREAM_MAXLEN=100000
REDIS_STREAM_TTL=604800

# Security
SECURITY_SECRET_KEY=your-secret-key-change-in-production
SECURITY_JWT_EXPIRY_HOURS=24
SECURITY_MAX_TOOL_CALLS_PER_MINUTE=60
SECURITY_MAX_CONCURRENT_AGENTS=10
SECURITY_ENABLE_CONSTITUTIONAL_AI=true
SECURITY_ENABLE_MITRE_ATLAS_MAPPING=true
SECURITY_PRIVILEGE_ESCALATION_THRESHOLD=3
SECURITY_AUTO_KILL_ON_VIOLATION=false
SECURITY_AUDIT_ALL_ACTIONS=true

# Agent Configuration
AGENT_MAX_PLANNING_STEPS=20
AGENT_MAX_CORRECTION_ATTEMPTS=3
AGENT_ENABLE_SELF_CORRECTION=true
AGENT_CRITIC_MODEL=gpt-4
AGENT_EXECUTOR_MODEL=gpt-4
AGENT_PLANNER_MODEL=gpt-4
AGENT_TEMPERATURE=0.1
